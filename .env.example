# ResumeWise — Environment Variables
# Copy to .env.local and fill in values.

# Master encryption key for BYOK API key storage (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# Google OAuth (Better Auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth session secret (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Optional: server-side OpenAI key fallback (used when user has no BYOK key)
# OPENAI_API_KEY=
