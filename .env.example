# ResumeWise — Environment Variables
# Copy to .env.local and fill in values.

# Master encryption key for BYOK API key storage (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# Better Auth
BETTER_AUTH_SECRET=       # openssl rand -hex 32
BETTER_AUTH_URL=          # https://your-domain.com

# Google OAuth (Better Auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare D1 (production database — leave empty for local sqlite)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# Optional: server-side OpenAI key fallback (used when user has no BYOK key)
# OPENAI_API_KEY=
